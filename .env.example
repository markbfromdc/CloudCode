# Cloud IDE Backend - Environment Variables
# Copy this file to .env and fill in the values.

# ---- Server ----
# HTTP_PORT: Port for the HTTP API server (default: 8080)
HTTP_PORT=8080
# GRPC_PORT: Port for the gRPC server (default: 9090)
GRPC_PORT=9090
# HOST_ADDR: Address to bind the server to (default: 0.0.0.0)
HOST_ADDR=0.0.0.0

# ---- TLS ----
# ENABLE_TLS: Set to true to enable HTTPS (default: false)
ENABLE_TLS=false
# TLS_CERT_PATH: Path to TLS certificate file (required if ENABLE_TLS=true)
TLS_CERT_PATH=
# TLS_KEY_PATH: Path to TLS private key file (required if ENABLE_TLS=true)
TLS_KEY_PATH=

# ---- Security ----
# JWT_SECRET: Secret key for JWT token validation (required)
JWT_SECRET=
# ALLOWED_ORIGINS: Allowed CORS origins (default: https://ide.cloudcode.dev)
ALLOWED_ORIGINS=http://localhost:3000
# SESSION_TIMEOUT_HOURS: Session expiration in hours (default: 24)
SESSION_TIMEOUT_HOURS=24

# ---- Rate Limiting ----
# RATE_LIMIT_RPS: Maximum requests per second per IP (default: 100)
RATE_LIMIT_RPS=100
# RATE_LIMIT_BURST: Maximum burst size per IP (default: 200)
RATE_LIMIT_BURST=200

# ---- WebSocket ----
# WS_READ_BUFFER_SIZE: WebSocket read buffer in bytes (default: 8192)
WS_READ_BUFFER_SIZE=8192
# WS_WRITE_BUFFER_SIZE: WebSocket write buffer in bytes (default: 8192)
WS_WRITE_BUFFER_SIZE=8192
# WS_PING_INTERVAL_SEC: Interval between WebSocket pings in seconds (default: 30)
WS_PING_INTERVAL_SEC=30
# WS_PONG_TIMEOUT_SEC: Max wait for pong response in seconds (default: 40)
WS_PONG_TIMEOUT_SEC=40
# WS_WRITE_TIMEOUT_SEC: Max wait for write completion in seconds (default: 10)
WS_WRITE_TIMEOUT_SEC=10
# WS_MAX_MESSAGE_SIZE: Maximum WebSocket message size in bytes (default: 65536)
WS_MAX_MESSAGE_SIZE=65536

# ---- Containers ----
# DOCKER_HOST: Docker daemon socket path (default: unix:///var/run/docker.sock)
DOCKER_HOST=unix:///var/run/docker.sock
# WORKSPACE_IMAGE: Docker image for workspace containers (default: cloudide-workspace:latest)
WORKSPACE_IMAGE=cloudide-workspace:latest
# CONTAINER_MEMORY_MB: Memory limit per container in MB (default: 4096)
CONTAINER_MEMORY_MB=4096
# CONTAINER_CPU_SHARES: CPU shares per container (default: 2048)
CONTAINER_CPU_SHARES=2048
# CONTAINER_TIMEOUT_MIN: Max container lifetime in minutes (default: 480)
CONTAINER_TIMEOUT_MIN=480
# DOCKER_NETWORK: Docker network name for containers (default: cloudide-net)
DOCKER_NETWORK=cloudide-net

# ---- Observability ----
# LOG_LEVEL: Logging level - debug, info, warn, error (default: info)
LOG_LEVEL=info

# ---- Shutdown ----
# SHUTDOWN_TIMEOUT_SEC: Graceful shutdown timeout in seconds (default: 30)
SHUTDOWN_TIMEOUT_SEC=30
